{
  "cases": [
    {
      "id": "deposit_missing_arrival_followup",
      "user_id": "10001",
      "turns": [
        {
          "user": "我的充值一直没到账",
          "expected_assistant_contains": "请提供充值 TxID",
          "expected_next_action_state": "awaiting_deposit_txid",
          "expected_trace": {
            "route": "knowledge_rag",
            "category": "deposit",
            "intent": "missing_arrival",
            "handling_result": "missing_deposit_txid",
            "entities": {},
            "missing_fields": ["txid"]
          }
        },
        {
          "user": "10002",
          "expected_assistant_contains": "未找到当前用户的充值记录 TX-10002",
          "expected_next_action_state": "awaiting_deposit_followup_details",
          "expected_trace": {
            "route": "business_query",
            "category": "deposit",
            "intent": "status_query",
            "handling_result": "business_deposit_not_found",
            "entities": {
              "txid": "TX-10002"
            },
            "missing_fields": []
          }
        },
        {
          "user": "USDT，TRC20，今天 14:30，页面显示链上成功但未到账",
          "expected_assistant_contains": "已记录你的补充信息",
          "expected_next_action_state": "manual_fallback_candidate",
          "expected_trace": {
            "route": "human_request",
            "category": "deposit",
            "intent": "followup_details",
            "handling_result": "deposit_followup_received"
          }
        }
      ]
    },
